[Unit]
Description=Wavelog-Hamlib rigctl bridge
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=0

[Service]
Type=simple
User=radio
Group=radio
WorkingDirectory=/opt/Wavelog-Hamlib
ExecStart=/usr/bin/python /opt/Wavelog-Hamlib/rigctl_cloudlog_interface.py --config /opt/Wavelog-Hamlib/config.json
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target